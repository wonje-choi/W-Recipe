main(class="min-h-full bg-zinc-50")
    section(class="border-b border-zinc-200 bg-white")
        div(class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8")
            div(class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between")
                div
                    h1(class="text-2xl font-semibold tracking-normal text-zinc-950") 관리자 Dashboard
                    p(class="mt-2 text-[13px] leading-6 text-zinc-500") 레시피 검수, 사용자 참여, AI 처리 상태를 한눈에 확인합니다.
                button(type="button", class="rounded-md border border-zinc-300 bg-white px-4 py-2 text-[13px] font-semibold text-zinc-700 hover:border-emerald-500 hover:text-emerald-700", (click)="load()") 새로고침

    section(class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8")
        div(*ngIf="loading", class="rounded-md bg-white p-6 text-[13px] text-zinc-500") 운영 지표를 불러오는 중입니다.
        p(*ngIf="message", class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-[13px] text-red-700") {{ message }}
        div(*ngIf="!loading", class="space-y-6")
            div(class="grid gap-3 sm:grid-cols-2 xl:grid-cols-6")
                button(*ngFor="let metric of metrics", type="button", class="rounded-md border bg-white p-4 text-left transition hover:shadow-sm", [ngClass]="toneClass(metric.tone)", (click)="go(metric.href)")
                    p(class="text-xs font-medium") {{ metric.label }}
                    p(class="mt-2 text-2xl font-semibold") {{ metric.value | number }}

            section(class="rounded-md border border-zinc-200 bg-white p-4 sm:p-5")
                div(class="flex flex-wrap items-start justify-between gap-3")
                    div
                        h2(class="text-lg font-semibold text-zinc-950") 오늘의 운영 신호
                        p(class="mt-1 text-xs text-zinc-500") {{ operations.measurementNote }}
                    span(class="rounded-md bg-zinc-100 px-2.5 py-1 text-xs text-zinc-600") Today
                div(class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-6")
                    div(class="rounded-md bg-sky-50 p-3")
                        p(class="text-xs text-sky-700") 방문자
                        p(class="mt-1 text-xl font-semibold text-sky-950") {{ operations.daily.visitors | number }}
                    div(class="rounded-md bg-emerald-50 p-3")
                        p(class="text-xs text-emerald-700") 레시피 조회
                        p(class="mt-1 text-xl font-semibold text-emerald-950") {{ operations.daily.recipeViews | number }}
                    div(class="rounded-md bg-indigo-50 p-3")
                        p(class="text-xs text-indigo-700") AI 요청
                        p(class="mt-1 text-xl font-semibold text-indigo-950") {{ operations.daily.aiRequests | number }}
                    div(class="rounded-md bg-zinc-50 p-3")
                        p(class="text-xs text-zinc-600") 가입
                        p(class="mt-1 text-xl font-semibold text-zinc-950") {{ operations.daily.signups | number }}
                    div(class="rounded-md bg-violet-50 p-3")
                        p(class="text-xs text-violet-700") 댓글
                        p(class="mt-1 text-xl font-semibold text-violet-950") {{ operations.daily.comments | number }}
                    div(class="rounded-md bg-rose-50 p-3")
                        p(class="text-xs text-rose-700") 신고
                        p(class="mt-1 text-xl font-semibold text-rose-950") {{ operations.daily.reports | number }}

            div(class="grid gap-6 lg:grid-cols-[1fr_1fr]")
                section(class="rounded-md border border-zinc-200 bg-white p-4 sm:p-5")
                    div(class="flex items-center justify-between gap-3")
                        h2(class="text-lg font-semibold text-zinc-950") 검수 대기
                        button(type="button", class="rounded-md bg-zinc-950 px-3 py-2 text-[13px] font-semibold text-white hover:bg-zinc-800", (click)="go('/admin/recipes?status=pending_review')") 검수로 이동
                    div(class="mt-4 space-y-3")
                        button(*ngFor="let item of reviewQueue", type="button", class="flex w-full items-center justify-between rounded-md border border-zinc-200 px-4 py-3 text-left hover:border-amber-400", (click)="go(item.href)")
                            span(class="text-[13px] font-medium text-zinc-700") {{ item.label }}
                            span(class="rounded-md bg-amber-50 px-2.5 py-1 text-xs font-semibold text-amber-700") {{ item.count | number }}

                section(class="rounded-md border border-zinc-200 bg-white p-4 sm:p-5")
                    h2(class="text-lg font-semibold text-zinc-950") 처리 품질
                    div(class="mt-4 grid gap-3 sm:grid-cols-2")
                        div(class="rounded-md bg-zinc-50 p-4")
                            p(class="text-xs text-zinc-500") AI 실패율
                            p(class="mt-1 text-2xl font-semibold text-zinc-950") {{ operations.aiFailureRate }}%
                            p(class="mt-1 text-xs text-zinc-500") 실패 {{ operations.aiFailed | number }}건 · 전체 {{ operations.aiRequests | number }}건
                        div(class="rounded-md bg-zinc-50 p-4")
                            p(class="text-xs text-zinc-500") 승인 비율
                            p(class="mt-1 text-2xl font-semibold text-zinc-950") {{ operations.approvalRate }}%
                            p(class="mt-1 text-xs text-zinc-500") 승인 {{ operations.approved | number }} · 반려 {{ operations.rejected | number }}
                        div(class="rounded-md bg-zinc-50 p-4")
                            p(class="text-xs text-zinc-500") 크롤링 실패율
                            p(class="mt-1 text-2xl font-semibold text-zinc-950") {{ operations.sourceFailureRate }}%
                            p(class="mt-1 text-xs text-zinc-500") 실패 {{ operations.sourceErrors | number }} · 전체 {{ operations.sourceCount | number }}
                        div(class="rounded-md bg-zinc-50 p-4")
                            p(class="text-xs text-zinc-500") AI 사용량
                            p(class="mt-1 text-2xl font-semibold text-zinc-950") {{ operations.tokenTotal | number }}
                            p(class="mt-1 text-xs text-zinc-500") 비용 {{ operations.costTotal | number:'1.4-4' }}

            div(class="grid gap-6 lg:grid-cols-[1fr_1fr]")
                section(class="rounded-md border border-zinc-200 bg-white p-4 sm:p-5")
                    h2(class="text-lg font-semibold text-zinc-950") 레시피 조회 지표
                    div(class="mt-4 grid gap-3 sm:grid-cols-3")
                        div(class="rounded-md bg-zinc-50 p-3")
                            p(class="text-xs text-zinc-500") 전체 조회
                            p(class="mt-1 text-xl font-semibold text-zinc-950") {{ operations.totalRecipeViews | number }}
                        div(class="rounded-md bg-sky-50 p-3")
                            p(class="text-xs text-sky-700") 저염식 조회
                            p(class="mt-1 text-xl font-semibold text-sky-950") {{ operations.lowSodiumViews | number }}
                        div(class="rounded-md bg-amber-50 p-3")
                            p(class="text-xs text-amber-700") 이유식 조회
                            p(class="mt-1 text-xl font-semibold text-amber-950") {{ operations.babyFoodViews | number }}
                    div(class="mt-4 space-y-2")
                        button(*ngFor="let item of operations.popularRecipes", type="button", class="flex w-full items-center justify-between rounded-md border border-zinc-200 px-3 py-2 text-left hover:border-emerald-300", (click)="go(item.href)")
                            div(class="min-w-0")
                                p(class="line-clamp-1 text-[13px] font-semibold text-zinc-950") {{ item.name }}
                                p(class="mt-0.5 text-xs text-zinc-500") {{ item.category || '일반' }}
                            span(class="shrink-0 rounded-md bg-zinc-100 px-2 py-1 text-xs text-zinc-600") {{ item.viewCount | number }}
                    div(*ngIf="operations.popularRecipes.length === 0", class="mt-4 rounded-md bg-zinc-50 p-3 text-[13px] text-zinc-500") 인기 레시피 데이터가 없습니다.

                section(class="rounded-md border border-zinc-200 bg-white p-4 sm:p-5")
                    h2(class="text-lg font-semibold text-zinc-950") 사용자 참여
                    div(class="mt-4 grid gap-3 sm:grid-cols-3")
                        div(class="rounded-md bg-zinc-50 p-3")
                            p(class="text-xs text-zinc-500") 가입 사용자
                            p(class="mt-1 text-xl font-semibold text-zinc-950") {{ operations.signups | number }}
                            p(class="mt-1 text-xs text-zinc-500") 오늘 {{ operations.todaySignups | number }}
                        div(class="rounded-md bg-zinc-50 p-3")
                            p(class="text-xs text-zinc-500") 댓글
                            p(class="mt-1 text-xl font-semibold text-zinc-950") {{ operations.comments | number }}
                            p(class="mt-1 text-xs text-zinc-500") 오늘 {{ operations.todayComments | number }}
                        div(class="rounded-md bg-zinc-50 p-3")
                            p(class="text-xs text-zinc-500") 신고
                            p(class="mt-1 text-xl font-semibold text-zinc-950") {{ operations.reports | number }}
                            p(class="mt-1 text-xs text-zinc-500") 오늘 {{ operations.todayReports | number }}
                    div(class="mt-4 flex flex-wrap gap-2")
                        button(type="button", class="rounded-md border border-zinc-200 bg-white px-3 py-1.5 text-xs font-medium text-zinc-700", (click)="go('/admin/feedback')") 참여 관리
                        button(type="button", class="rounded-md border border-zinc-200 bg-white px-3 py-1.5 text-xs font-medium text-zinc-700", (click)="go('/admin/logs')") 로그 보기
                        button(type="button", class="rounded-md border border-zinc-200 bg-white px-3 py-1.5 text-xs font-medium text-zinc-700", (click)="go('/admin/ai')") AI 관리

            div(class="grid gap-6 lg:grid-cols-2")
                section(class="rounded-md border border-zinc-200 bg-white p-4 sm:p-5")
                    div(class="flex items-center justify-between gap-3")
                        h2(class="text-lg font-semibold text-zinc-950") 최근 수집 외부 자료
                        button(type="button", class="text-[13px] font-semibold text-emerald-700", (click)="go('/admin/sources')") 전체 보기
                    div(*ngIf="operations.recentSources.length === 0", class="mt-4 rounded-md bg-zinc-50 p-3 text-[13px] text-zinc-500") 최근 수집 자료가 없습니다.
                    div(class="mt-4 space-y-2")
                        article(*ngFor="let item of operations.recentSources", class="rounded-md border border-zinc-200 p-3")
                            div(class="flex items-center justify-between gap-3")
                                p(class="line-clamp-1 text-[13px] font-semibold text-zinc-950") {{ item.title || item.id }}
                                span(class="rounded-md bg-zinc-100 px-2 py-1 text-xs text-zinc-600") {{ item.status || '-' }}
                            p(class="mt-1 text-xs text-zinc-500") {{ item.createdAt }}
                section(class="rounded-md border border-zinc-200 bg-white p-4 sm:p-5")
                    div(class="flex items-center justify-between gap-3")
                        h2(class="text-lg font-semibold text-zinc-950") AI 실패 로그
                        button(type="button", class="text-[13px] font-semibold text-emerald-700", (click)="go('/admin/ai?tab=logs&status=failed')") 로그 보기
                    div(*ngIf="operations.failedLogs.length === 0", class="mt-4 rounded-md bg-zinc-50 p-3 text-[13px] text-zinc-500") 실패 로그가 없습니다.
                    div(class="mt-4 space-y-2")
                        article(*ngFor="let item of operations.failedLogs", class="rounded-md border border-zinc-200 p-3")
                            div(class="flex items-center justify-between gap-3")
                                p(class="line-clamp-1 text-[13px] font-semibold text-zinc-950") {{ item.title || item.id }}
                                span(class="rounded-md bg-red-50 px-2 py-1 text-xs text-red-700") 실패
                            p(class="mt-1 line-clamp-2 text-xs text-zinc-500") {{ item.errorMessage || '오류 메시지 없음' }}
