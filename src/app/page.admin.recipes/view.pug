section(class="min-h-full bg-zinc-50 px-4 py-5 sm:px-6 lg:px-8")
    div(class="mx-auto flex max-w-7xl flex-col gap-4")
        header(class="flex flex-col gap-3 border-b border-zinc-200 pb-4 lg:flex-row lg:items-end lg:justify-between")
            div
                p(class="text-xs font-medium text-emerald-700") 관리자
                h1(class="mt-1 text-lg font-semibold text-zinc-950") 레시피 관리
                p(class="mt-1 text-[13px] text-zinc-600") 등록, 상태 검수, 공개 여부, 출처 정보를 한 화면에서 운영합니다.
            div(class="flex flex-wrap items-center gap-2")
                button(type="button", (click)="openNew()", class="rounded-md bg-emerald-600 px-3 py-2 text-[13px] font-medium text-white hover:bg-emerald-700") 새 레시피
                button(type="button", (click)="load()", class="rounded-md border border-zinc-300 bg-white px-3 py-2 text-[13px] font-medium text-zinc-700 hover:bg-zinc-100") 새로고침

        div(class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_440px]")
            div(class="flex min-w-0 flex-col gap-4")
                div(class="rounded-lg border border-zinc-200 bg-white p-3")
                    div(class="grid gap-2 lg:grid-cols-[minmax(180px,1fr)_150px_150px_150px_auto]")
                        input(type="search", [(ngModel)]="filters.text", name="adminRecipeText", (keyup.enter)="search()", class="min-h-[38px] rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600", placeholder="레시피 이름 검색")
                        select([(ngModel)]="filters.status", name="adminRecipeStatus", class="min-h-[38px] rounded-md border border-zinc-300 bg-white px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            option(value="") 모든 상태
                            option(*ngFor="let status of options.recipeStatuses", [value]="status.value") {{ status.label }}
                        select([(ngModel)]="filters.category", name="adminRecipeCategory", class="min-h-[38px] rounded-md border border-zinc-300 bg-white px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            option(value="") 모든 카테고리
                            option(*ngFor="let category of options.categories", [value]="category") {{ category }}
                        select([(ngModel)]="filters.tag", name="adminRecipeTag", class="min-h-[38px] rounded-md border border-zinc-300 bg-white px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            option(value="") 모든 태그
                            option(*ngFor="let tag of options.tags", [value]="tag") {{ tag }}
                        div(class="flex gap-2")
                            button(type="button", (click)="search()", class="min-h-[38px] rounded-md bg-zinc-900 px-3 text-[13px] font-medium text-white hover:bg-zinc-700") 검색
                            button(type="button", (click)="resetFilters()", class="min-h-[38px] rounded-md border border-zinc-300 bg-white px-3 text-[13px] font-medium text-zinc-700 hover:bg-zinc-100") 초기화

                div(*ngIf="message", class="rounded-md border border-rose-200 bg-rose-50 px-3 py-2 text-[13px] text-rose-700") {{ message }}
                div(*ngIf="loading", class="rounded-lg border border-zinc-200 bg-white p-8 text-center text-[13px] text-zinc-500") 레시피 목록을 불러오는 중입니다.

                div(*ngIf="!loading", class="overflow-hidden rounded-lg border border-zinc-200 bg-white")
                    div(class="flex items-center justify-between border-b border-zinc-200 px-4 py-3")
                        p(class="text-[13px] font-medium text-zinc-800") 총 {{ total }}개
                        p(class="text-xs text-zinc-500") {{ page }} / {{ totalPages }} 페이지
                    div(class="overflow-x-auto")
                        table(class="min-w-full divide-y divide-zinc-200 text-left text-[13px]")
                            thead(class="bg-zinc-50 text-xs font-semibold text-zinc-500")
                                tr
                                    th(class="w-[34%] px-4 py-3") 레시피
                                    th(class="px-4 py-3") 분류
                                    th(class="px-4 py-3") 상태
                                    th(class="px-4 py-3") 조회
                                    th(class="px-4 py-3 text-right") 관리
                            tbody(class="divide-y divide-zinc-100 bg-white")
                                tr(*ngFor="let item of items", class="align-top hover:bg-zinc-50")
                                    td(class="px-4 py-3")
                                        div(class="flex gap-3")
                                            div(class="flex size-14 shrink-0 items-center justify-center overflow-hidden rounded-md bg-zinc-100")
                                                img(*ngIf="item.hasImage", [src]="item.thumbnailUrl", [alt]="item.name", class="h-full w-full object-cover")
                                                span(*ngIf="!item.hasImage", class="text-xs text-zinc-400") 이미지
                                            div(class="min-w-0")
                                                button(type="button", (click)="edit(item)", class="line-clamp-1 text-left text-[13px] font-semibold text-zinc-950 hover:text-emerald-700") {{ item.name }}
                                                p(class="mt-1 line-clamp-2 text-xs text-zinc-500") {{ item.description || '설명이 없습니다.' }}
                                                div(class="mt-2 flex flex-wrap gap-1")
                                                    span(*ngFor="let tag of item.tags", class="rounded border border-zinc-200 bg-zinc-50 px-1.5 py-0.5 text-[11px] text-zinc-600") {{ tag }}
                                    td(class="px-4 py-3 text-zinc-700") {{ item.category || '-' }}
                                    td(class="px-4 py-3")
                                        span([ngClass]="statusClass(item.status)", class="inline-flex rounded border px-2 py-1 text-xs font-medium") {{ statusLabel(item.status) }}
                                        select([ngModel]="item.status", (ngModelChange)="changeDishStatus(item, $event)", name="dishStatus{{item.id}}", class="mt-2 block w-full min-w-[120px] rounded-md border border-zinc-300 bg-white px-2 py-1.5 text-xs outline-none focus:border-emerald-600")
                                            option(*ngFor="let status of options.recipeStatuses", [value]="status.value") {{ status.label }}
                                    td(class="px-4 py-3 text-zinc-600") {{ item.viewCount || 0 }}
                                    td(class="px-4 py-3")
                                        div(class="flex justify-end gap-2")
                                            button(type="button", (click)="edit(item)", class="rounded-md border border-zinc-300 bg-white px-2.5 py-1.5 text-xs font-medium text-zinc-700 hover:bg-zinc-100") 수정
                                            button(type="button", (click)="hideDish(item)", class="rounded-md border border-rose-200 bg-rose-50 px-2.5 py-1.5 text-xs font-medium text-rose-700 hover:bg-rose-100") 숨김
                                tr(*ngIf="items.length === 0")
                                    td(colspan="5", class="px-4 py-10 text-center text-[13px] text-zinc-500") 조건에 맞는 레시피가 없습니다.
                    div(class="flex items-center justify-between border-t border-zinc-200 px-4 py-3")
                        button(type="button", (click)="prevPage()", [disabled]="page <= 1", class="rounded-md border border-zinc-300 bg-white px-3 py-1.5 text-xs font-medium text-zinc-700 disabled:cursor-not-allowed disabled:opacity-40") 이전
                        button(type="button", (click)="nextPage()", [disabled]="page >= totalPages", class="rounded-md border border-zinc-300 bg-white px-3 py-1.5 text-xs font-medium text-zinc-700 disabled:cursor-not-allowed disabled:opacity-40") 다음

            aside(class="min-w-0")
                div(*ngIf="!formOpen", class="rounded-lg border border-zinc-200 bg-white p-5 text-[13px] text-zinc-600")
                    p(class="font-medium text-zinc-900") 편집할 레시피를 선택하세요.
                    p(class="mt-2") 목록에서 수정 버튼을 누르거나 새 레시피를 등록할 수 있습니다.
                div(*ngIf="formOpen", class="rounded-lg border border-zinc-200 bg-white")
                    div(class="flex items-center justify-between border-b border-zinc-200 px-4 py-3")
                        div
                            p(class="text-[13px] font-semibold text-zinc-950") {{ dishForm.id ? '레시피 수정' : '새 레시피' }}
                            p(class="mt-0.5 text-xs text-zinc-500") 공개 상태와 대표 버전 정보를 함께 저장합니다.
                        button(type="button", (click)="closeForm()", class="rounded-md border border-zinc-300 bg-white px-2.5 py-1.5 text-xs font-medium text-zinc-700 hover:bg-zinc-100") 닫기

                    div(class="flex max-h-[calc(100vh-180px)] flex-col gap-5 overflow-auto p-4")
                        div(*ngIf="formMessage", class="rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-[13px] text-amber-800") {{ formMessage }}

                        section(class="space-y-3")
                            h2(class="text-[15px] font-semibold text-zinc-950") 기본 정보
                            label(class="block text-xs font-medium text-zinc-600") 레시피 이름
                                input(type="text", [(ngModel)]="dishForm.name", name="dishName", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            label(class="block text-xs font-medium text-zinc-600") 설명
                                textarea([(ngModel)]="dishForm.description", name="dishDescription", rows="3", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            div(class="grid gap-3 sm:grid-cols-2")
                                label(class="block text-xs font-medium text-zinc-600") 카테고리
                                    select([(ngModel)]="dishForm.category", name="dishCategory", class="mt-1 block w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                                        option(*ngFor="let category of options.categories", [value]="category") {{ category }}
                                label(class="block text-xs font-medium text-zinc-600") 공개/검수 상태
                                    select([(ngModel)]="dishForm.status", name="dishFormStatus", class="mt-1 block w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                                        option(*ngFor="let status of options.recipeStatuses", [value]="status.value") {{ status.label }}
                            label(class="block text-xs font-medium text-zinc-600") 대표 이미지 URL
                                input(type="url", [(ngModel)]="dishForm.thumbnailUrl", name="dishThumbnail", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600", placeholder="https://")
                            div
                                p(class="text-xs font-medium text-zinc-600") 태그
                                div(class="mt-2 flex flex-wrap gap-1.5")
                                    button(*ngFor="let tag of options.tags", type="button", (click)="toggleTag(tag)", [ngClass]="isTagSelected(tag) ? 'border-emerald-600 bg-emerald-600 text-white' : 'border-zinc-200 bg-white text-zinc-600 hover:bg-zinc-50'", class="rounded-md border px-2 py-1 text-xs font-medium") {{ tag }}

                        section(class="space-y-3 border-t border-zinc-200 pt-4")
                            div(class="flex items-center justify-between gap-2")
                                h2(class="text-[15px] font-semibold text-zinc-950") 대표 버전
                                button(type="button", (click)="createVersion()", [disabled]="!dishForm.id", class="rounded-md border border-zinc-300 bg-white px-2.5 py-1.5 text-xs font-medium text-zinc-700 disabled:cursor-not-allowed disabled:opacity-40") 버전 추가
                            div(class="rounded-md border border-emerald-100 bg-emerald-50 p-3")
                                div(class="flex items-center justify-between gap-3")
                                    div
                                        p(class="text-[13px] font-semibold text-emerald-900") AI 콘텐츠 생성
                                        p(class="mt-1 text-xs text-emerald-700") 저장된 레시피 버전을 바탕으로 제목, 설명, 영상 대본을 생성합니다.
                                    button(type="button", (click)="generateMeta()", [disabled]="generatingMeta || !dishForm.id", class="rounded-md bg-emerald-600 px-3 py-2 text-xs font-medium text-white hover:bg-emerald-700 disabled:cursor-not-allowed disabled:opacity-50") {{ generatingMeta ? '생성 중' : 'AI 생성' }}
                                p(*ngIf="generatedMetaMessage", class="mt-2 text-xs text-rose-700") {{ generatedMetaMessage }}
                                div(*ngIf="generatedMeta", class="mt-3 space-y-3")
                                    div(class="rounded-md bg-white p-3")
                                        div(class="flex items-start justify-between gap-2")
                                            div
                                                p(class="text-xs font-semibold text-zinc-500") 제목
                                                p(class="mt-1 text-[13px] text-zinc-800") {{ generatedMeta.title }}
                                            button(type="button", (click)="applyGenerated('title')", class="rounded-md border border-zinc-200 px-2 py-1 text-xs text-zinc-700 hover:bg-zinc-50") 적용
                                    div(class="rounded-md bg-white p-3")
                                        div(class="flex items-start justify-between gap-2")
                                            div
                                                p(class="text-xs font-semibold text-zinc-500") 설명
                                                p(class="mt-1 text-[13px] leading-5 text-zinc-800") {{ generatedMeta.description }}
                                            button(type="button", (click)="applyGenerated('description')", class="rounded-md border border-zinc-200 px-2 py-1 text-xs text-zinc-700 hover:bg-zinc-50") 적용
                                    div(class="rounded-md bg-white p-3")
                                        div(class="flex items-start justify-between gap-2")
                                            div(class="min-w-0")
                                                p(class="text-xs font-semibold text-zinc-500") 영상 대본
                                                pre(class="mt-1 max-h-36 overflow-auto whitespace-pre-wrap text-xs leading-5 text-zinc-800") {{ generatedMeta.script }}
                                            button(type="button", (click)="applyGenerated('script')", class="rounded-md border border-zinc-200 px-2 py-1 text-xs text-zinc-700 hover:bg-zinc-50") 적용
                            div(class="rounded-md border border-sky-100 bg-sky-50 p-3")
                                div(class="flex items-center justify-between gap-3")
                                    div
                                        p(class="text-[13px] font-semibold text-sky-900") 유튜브 업로드 준비
                                        p(class="mt-1 text-xs text-sky-700") 영상 제목, 설명, 태그와 업로드 API 호출 정보를 미리 확인합니다.
                                    button(type="button", (click)="prepareYoutubeUpload()", [disabled]="preparingYoutube || !dishForm.id", class="rounded-md bg-sky-600 px-3 py-2 text-xs font-medium text-white hover:bg-sky-700 disabled:cursor-not-allowed disabled:opacity-50") {{ preparingYoutube ? '준비 중' : '미리보기' }}
                                p(*ngIf="youtubeMessage", class="mt-2 text-xs text-rose-700") {{ youtubeMessage }}
                                div(*ngIf="youtubePreview", class="mt-3 space-y-3 rounded-md bg-white p-3")
                                    div(class="flex items-start justify-between gap-2")
                                        div
                                            p(class="text-xs font-semibold text-zinc-500") 업로드 엔드포인트
                                            p(class="mt-1 break-all text-xs text-zinc-700") {{ youtubePreview.uploadEndpoint }}
                                        button(type="button", (click)="closeYoutubePreview()", class="rounded-md border border-zinc-200 px-2 py-1 text-xs text-zinc-700 hover:bg-zinc-50") 닫기
                                    div
                                        p(class="text-xs font-semibold text-zinc-500") 제목
                                        p(class="mt-1 text-[13px] text-zinc-800") {{ youtubePreview.title }}
                                    div
                                        p(class="text-xs font-semibold text-zinc-500") 설명
                                        pre(class="mt-1 max-h-40 overflow-auto whitespace-pre-wrap text-xs leading-5 text-zinc-800") {{ youtubePreview.description }}
                                    div
                                        p(class="text-xs font-semibold text-zinc-500") 태그
                                        div(class="mt-2 flex flex-wrap gap-1")
                                            span(*ngFor="let tag of youtubePreview.tags", class="rounded border border-zinc-200 bg-zinc-50 px-2 py-1 text-[11px] text-zinc-600") {{ tag }}
                            div(*ngIf="versions.length", class="flex flex-wrap gap-1.5")
                                button(*ngFor="let version of versions", type="button", (click)="selectVersion(version)", [ngClass]="selectedVersionId === version.id ? 'border-emerald-600 bg-emerald-50 text-emerald-700' : 'border-zinc-200 bg-white text-zinc-600'", class="rounded-md border px-2 py-1 text-xs font-medium") {{ version.title }} · {{ statusLabel(version.status) }}
                            label(class="block text-xs font-medium text-zinc-600") 버전 제목
                                input(type="text", [(ngModel)]="versionForm.title", name="versionTitle", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            div(class="grid gap-3 sm:grid-cols-2")
                                label(class="block text-xs font-medium text-zinc-600") 버전 상태
                                    select([(ngModel)]="versionForm.status", name="versionStatus", class="mt-1 block w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                                        option(*ngFor="let status of options.recipeStatuses", [value]="status.value") {{ status.label }}
                                label(class="block text-xs font-medium text-zinc-600") 난이도
                                    select([(ngModel)]="versionForm.difficulty", name="versionDifficulty", class="mt-1 block w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                                        option(*ngFor="let difficulty of options.difficultyOptions", [value]="difficulty.value") {{ difficulty.label }}
                            div(class="grid gap-3 sm:grid-cols-2")
                                label(class="block text-xs font-medium text-zinc-600") 조리 시간(분)
                                    input(type="number", min="0", [(ngModel)]="versionForm.cookingTime", name="versionCookingTime", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                                label(class="block text-xs font-medium text-zinc-600") 분량
                                    input(type="text", [(ngModel)]="versionForm.servingSize", name="versionServingSize", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600", placeholder="2인분")
                            label(class="block text-xs font-medium text-zinc-600") 요약
                                textarea([(ngModel)]="versionForm.summary", name="versionSummary", rows="3", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")

                        section(class="space-y-3 border-t border-zinc-200 pt-4")
                            h2(class="text-[15px] font-semibold text-zinc-950") 출처
                            div(class="grid gap-3 sm:grid-cols-2")
                                label(class="block text-xs font-medium text-zinc-600") 출처 유형
                                    select([(ngModel)]="versionForm.sourceType", name="versionSourceType", class="mt-1 block w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                                        option(*ngFor="let source of options.sourceTypes", [value]="source.value") {{ source.label }}
                                label(class="block text-xs font-medium text-zinc-600") 작성자
                                    input(type="text", [(ngModel)]="versionForm.sourceAuthor", name="versionSourceAuthor", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            label(class="block text-xs font-medium text-zinc-600") 출처 제목
                                input(type="text", [(ngModel)]="versionForm.sourceTitle", name="versionSourceTitle", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            label(class="block text-xs font-medium text-zinc-600") 출처 URL
                                input(type="url", [(ngModel)]="versionForm.sourceUrl", name="versionSourceUrl", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600", placeholder="https://")

                        section(class="space-y-3 border-t border-zinc-200 pt-4")
                            h2(class="text-[15px] font-semibold text-zinc-950") 조리 콘텐츠
                            label(class="block text-xs font-medium text-zinc-600") 재료(줄 단위)
                                textarea([(ngModel)]="versionForm.ingredientsText", name="versionIngredients", rows="5", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            label(class="block text-xs font-medium text-zinc-600") 조리 단계(줄 단위)
                                textarea([(ngModel)]="versionForm.stepsText", name="versionSteps", rows="6", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            label(class="block text-xs font-medium text-zinc-600") 조리 팁(줄 단위)
                                textarea([(ngModel)]="versionForm.cookingTipsText", name="versionTips", rows="3", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            label(class="block text-xs font-medium text-zinc-600") 실패 방지 팁(줄 단위)
                                textarea([(ngModel)]="versionForm.failurePreventionTipsText", name="versionFailureTips", rows="3", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            label(class="block text-xs font-medium text-zinc-600") 대체 재료 팁(줄 단위)
                                textarea([(ngModel)]="versionForm.substitutionTipsText", name="versionSubstitutionTips", rows="3", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")

                        section(class="space-y-3 border-t border-zinc-200 pt-4")
                            h2(class="text-[15px] font-semibold text-zinc-950") 안전/영양 정보
                            label(class="block text-xs font-medium text-zinc-600") 영양 정보 JSON
                                textarea([(ngModel)]="versionForm.nutritionText", name="versionNutrition", rows="4", class="mt-1 block w-full font-mono rounded-md border border-zinc-300 px-3 py-2 text-xs outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            label(class="block text-xs font-medium text-zinc-600") 나트륨 정보 JSON
                                textarea([(ngModel)]="versionForm.sodiumText", name="versionSodium", rows="4", class="mt-1 block w-full font-mono rounded-md border border-zinc-300 px-3 py-2 text-xs outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            label(class="block text-xs font-medium text-zinc-600") 알레르기 정보(줄 단위)
                                textarea([(ngModel)]="versionForm.allergenText", name="versionAllergen", rows="3", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")

                    div(class="flex items-center justify-between gap-2 border-t border-zinc-200 px-4 py-3")
                        button(type="button", (click)="hideVersion()", [disabled]="!versionForm.id || saving", class="rounded-md border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-medium text-rose-700 disabled:cursor-not-allowed disabled:opacity-40") 버전 숨김
                        div(class="flex gap-2")
                            button(type="button", (click)="closeForm()", class="rounded-md border border-zinc-300 bg-white px-3 py-2 text-xs font-medium text-zinc-700 hover:bg-zinc-100") 취소
                            button(type="button", (click)="save()", [disabled]="saving", class="rounded-md bg-emerald-600 px-3 py-2 text-xs font-medium text-white hover:bg-emerald-700 disabled:cursor-wait disabled:opacity-60") {{ saving ? '저장 중' : '저장' }}
