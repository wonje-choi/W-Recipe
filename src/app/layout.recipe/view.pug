div(class="min-h-screen bg-zinc-50 text-zinc-950")
    header(class="sticky top-0 z-40 border-b border-zinc-200 bg-white/95 backdrop-blur")
        div(class="mx-auto flex h-14 max-w-7xl items-center gap-3 px-4 sm:px-6 lg:px-8")
            button(type="button", class="inline-flex size-9 items-center justify-center rounded-md border border-zinc-200 text-zinc-700 hover:bg-zinc-100 lg:hidden", (click)="toggleMobile()", [attr.aria-label]="t('layout.menu', '메뉴')")
                svg(class="size-4", fill="none", viewBox="0 0 24 24", stroke="currentColor", stroke-width="2")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M4 6h16M4 12h16M4 18h16")

            button(type="button", class="flex min-w-0 items-center gap-2", (click)="go('/')")
                span(class="flex size-8 shrink-0 items-center justify-center rounded-md bg-emerald-600 text-[13px] font-semibold text-white") RT
                span(class="truncate text-[15px] font-semibold text-zinc-950") Recipe Taste

            nav(class="hidden min-w-0 flex-1 items-center gap-1 lg:flex")
                button(*ngFor="let item of visibleItems()", type="button", class="rounded-md px-3 py-2 text-[13px] font-medium transition-colors", [class.bg-zinc-100]="isActive(item.href)", [class.text-zinc-950]="isActive(item.href)", [class.text-zinc-600]="!isActive(item.href)", (click)="go(item.href)") {{ label(item) }}
                button(*ngIf="isAdmin()", type="button", class="rounded-md px-3 py-2 text-[13px] font-medium text-zinc-600 transition-colors hover:bg-zinc-100 hover:text-zinc-950", [class.bg-zinc-100]="isActive('/admin')", (click)="go('/admin/dashboard')") {{ t('nav.adminDashboard', 'Admin Dashboard') }}

            div(class="ml-auto flex shrink-0 items-center gap-2")
                div(*ngIf="user", class="hidden items-center gap-2 sm:flex")
                    span(class="max-w-[160px] truncate text-[13px] text-zinc-600") {{ user.nickname || user.email }}
                    button(type="button", class="rounded-md border border-zinc-200 px-3 py-2 text-[13px] font-medium text-zinc-700 hover:bg-zinc-100", (click)="logout()") {{ t('auth.logout', '로그아웃') }}
                div(class="inline-flex rounded-md border border-zinc-200 p-0.5")
                    button(type="button", (click)="switchLang('ko')", [class.bg-zinc-950]="currentLang === 'ko'", [class.text-white]="currentLang === 'ko'", [class.text-zinc-600]="currentLang !== 'ko'", class="rounded px-2 py-1 text-xs font-medium") KO
                    button(type="button", (click)="switchLang('en')", [class.bg-zinc-950]="currentLang === 'en'", [class.text-white]="currentLang === 'en'", [class.text-zinc-600]="currentLang !== 'en'", class="rounded px-2 py-1 text-xs font-medium") EN
                button(*ngIf="!user", type="button", class="rounded-md bg-emerald-600 px-3 py-2 text-[13px] font-semibold text-white hover:bg-emerald-700", (click)="openLogin('user')") {{ t('auth.login', '로그인') }}

    div(*ngIf="mobileOpen", class="fixed inset-0 z-50 lg:hidden")
        button(type="button", class="absolute inset-0 bg-black/40", (click)="closeMobile()", [attr.aria-label]="t('layout.close', '닫기')")
        aside(class="relative flex h-full w-[280px] max-w-[85vw] flex-col border-r border-zinc-200 bg-white shadow-xl")
            div(class="flex h-14 items-center justify-between border-b border-zinc-200 px-4")
                div(class="flex items-center gap-2")
                    span(class="flex size-8 items-center justify-center rounded-md bg-emerald-600 text-[13px] font-semibold text-white") RT
                    span(class="text-[15px] font-semibold") Recipe Taste
                button(type="button", class="inline-flex size-9 items-center justify-center rounded-md text-zinc-600 hover:bg-zinc-100", (click)="closeMobile()", [attr.aria-label]="t('layout.close', '닫기')")
                    svg(class="size-4", fill="none", viewBox="0 0 24 24", stroke="currentColor", stroke-width="2")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M6 18L18 6M6 6l12 12")
            nav(class="flex flex-1 flex-col gap-1 overflow-auto p-3")
                button(*ngFor="let item of visibleItems()", type="button", class="rounded-md px-3 py-2 text-left text-[13px] font-medium", [class.bg-zinc-100]="isActive(item.href)", [class.text-zinc-950]="isActive(item.href)", [class.text-zinc-600]="!isActive(item.href)", (click)="go(item.href)") {{ label(item) }}
                button(*ngIf="isAdmin()", type="button", class="rounded-md px-3 py-2 text-left text-[13px] font-medium text-zinc-600 hover:bg-zinc-100", (click)="go('/admin/dashboard')") {{ t('nav.adminDashboard', 'Admin Dashboard') }}
            div(class="border-t border-zinc-200 p-3")
                div(*ngIf="user", class="space-y-2")
                    div(class="truncate text-[13px] font-medium text-zinc-700") {{ user.nickname || user.email }}
                    button(type="button", class="w-full rounded-md border border-zinc-200 px-3 py-2 text-[13px] font-medium text-zinc-700 hover:bg-zinc-100", (click)="logout()") {{ t('auth.logout', '로그아웃') }}
                button(*ngIf="!user", type="button", class="w-full rounded-md bg-emerald-600 px-3 py-2 text-[13px] font-semibold text-white hover:bg-emerald-700", (click)="openLogin('user')") {{ t('auth.login', '로그인') }}

    main(class="min-h-[calc(100vh-56px)]")
        router-outlet

    div(*ngIf="loginOpen", class="fixed inset-0 z-50 flex items-center justify-center bg-black/45 px-4 py-6")
        button(type="button", class="absolute inset-0", (click)="closeLogin()", aria-label="닫기")
        section(class="relative w-full max-w-[420px] rounded-lg bg-white shadow-xl")
            div(class="flex items-center justify-between border-b border-zinc-200 px-5 py-4")
                h2(class="text-[15px] font-semibold text-zinc-950") {{ t('auth.loginTitle', '로그인') }}
                button(type="button", class="inline-flex size-8 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100", (click)="closeLogin()", [attr.aria-label]="t('layout.close', '닫기')")
                    svg(class="size-4", fill="none", viewBox="0 0 24 24", stroke="currentColor", stroke-width="2")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M6 18L18 6M6 6l12 12")

            div(class="px-5 pt-4")
                div(class="grid grid-cols-2 rounded-md border border-zinc-200 p-1")
                    button(type="button", class="rounded px-3 py-2 text-[13px] font-medium", [class.bg-zinc-950]="loginTab === 'user'", [class.text-white]="loginTab === 'user'", [class.text-zinc-600]="loginTab !== 'user'", (click)="selectLoginTab('user')") {{ t('auth.userLogin', '일반 로그인') }}
                    button(type="button", class="rounded px-3 py-2 text-[13px] font-medium", [class.bg-zinc-950]="loginTab === 'admin'", [class.text-white]="loginTab === 'admin'", [class.text-zinc-600]="loginTab !== 'admin'", (click)="selectLoginTab('admin')") {{ t('auth.adminLogin', '관리자 로그인') }}

            form(class="space-y-4 px-5 py-5", (submit)="$event.preventDefault(); login()")
                div
                    label(class="mb-1 block text-[13px] font-medium text-zinc-700") {{ t('auth.email', '이메일') }}
                    input(type="email", autocomplete="email", [(ngModel)]="loginForm.email", name="recipeEmail", class="block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] text-zinc-950 outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600", placeholder="name@example.com")
                div
                    label(class="mb-1 block text-[13px] font-medium text-zinc-700") {{ t('auth.password', '비밀번호') }}
                    input(type="password", autocomplete="current-password", [(ngModel)]="loginForm.password", name="recipePassword", class="block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] text-zinc-950 outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600", [placeholder]="t('auth.passwordPlaceholder', '비밀번호')")
                p(*ngIf="loginError", class="rounded-md bg-red-50 px-3 py-2 text-[13px] text-red-700") {{ loginError }}
                button(type="submit", class="w-full rounded-md bg-emerald-600 px-3 py-2.5 text-[13px] font-semibold text-white hover:bg-emerald-700 disabled:cursor-not-allowed disabled:bg-zinc-300", [disabled]="loginLoading") {{ loginLoading ? t('auth.loggingIn', '로그인 중') : t('auth.login', '로그인') }}

wiz-portal-season-modal

div(*ngIf="service.status.loading", class="fixed left-0 top-0 z-50 flex h-full w-full items-center justify-center bg-black/20 backdrop-blur")
    wiz-portal-season-loading-season(className="w-12 h-12 text-emerald-600 animate-spin duration-700")
