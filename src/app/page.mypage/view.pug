main(class="min-h-full bg-zinc-50")
    section(class="border-b border-zinc-200 bg-white")
        div(class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8")
            div(class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between")
                div
                    h1(class="text-2xl font-semibold tracking-normal text-zinc-950") 마이페이지
                    p(class="mt-2 text-[13px] leading-6 text-zinc-500") 저장한 레시피, 최근 활동, 개인화 설정을 관리합니다.
                div(*ngIf="profile", class="rounded-md border border-emerald-100 bg-emerald-50 px-4 py-3 text-[13px] text-emerald-800") {{ profile.nickname || profile.email }} · {{ profile.role }} · {{ subscriptionLabel() }}

    section(class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8")
        div(*ngIf="loading", class="rounded-md bg-white p-6 text-[13px] text-zinc-500") 마이페이지를 불러오는 중입니다.
        div(*ngIf="!loading", class="space-y-6")
            div(class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5")
                div(class="rounded-md border border-zinc-200 bg-white p-4")
                    p(class="text-xs text-zinc-500") 저장한 레시피
                    p(class="mt-1 text-2xl font-semibold text-zinc-950") {{ countOf('favorites') }}
                div(class="rounded-md border border-zinc-200 bg-white p-4")
                    p(class="text-xs text-zinc-500") 최근 본 레시피
                    p(class="mt-1 text-2xl font-semibold text-zinc-950") {{ countOf('recentViews') }}
                div(class="rounded-md border border-zinc-200 bg-white p-4")
                    p(class="text-xs text-zinc-500") 댓글
                    p(class="mt-1 text-2xl font-semibold text-zinc-950") {{ countOf('comments') }}
                div(class="rounded-md border border-zinc-200 bg-white p-4")
                    p(class="text-xs text-zinc-500") 수정 요청
                    p(class="mt-1 text-2xl font-semibold text-zinc-950") {{ countOf('editRequests') }}
                div(class="rounded-md border border-zinc-200 bg-white p-4")
                    p(class="text-xs text-zinc-500") AI 개량 요청
                    p(class="mt-1 text-2xl font-semibold text-zinc-950") {{ countOf('aiModifications') }}

            div(class="flex flex-wrap gap-2")
                button(*ngFor="let tab of tabs", type="button", class="rounded-md px-4 py-2 text-[13px] font-semibold", [class.bg-zinc-950]="activeTab === tab.value", [class.text-white]="activeTab === tab.value", [class.bg-white]="activeTab !== tab.value", [class.text-zinc-600]="activeTab !== tab.value", (click)="selectTab(tab.value)") {{ tab.label }}

            p(*ngIf="message", class="rounded-md border border-zinc-200 bg-white px-4 py-3 text-[13px] text-zinc-700") {{ message }}

            section(*ngIf="profile", class="rounded-md border border-zinc-200 bg-white p-4")
                div(class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between")
                    div
                        h2(class="text-[15px] font-semibold text-zinc-950") 구독 현황
                        p(class="mt-1 text-[13px] text-zinc-600") 현재 플랜: {{ subscriptionLabel() }} · 만료일: {{ subscriptionExpiresAt() }}
                    div(class="rounded-md border border-zinc-200 bg-zinc-50 px-3 py-2 text-xs leading-5 text-zinc-600") Premium 활성화는 결제 연동 없이 관리자가 수동 처리합니다.

            section(*ngIf="activeTab === 'activity'", class="grid gap-6 lg:grid-cols-2")
                div(class="rounded-md border border-zinc-200 bg-white p-4")
                    h2(class="text-[15px] font-semibold text-zinc-950") 저장한 레시피
                    div(*ngIf="activity.favorites.items.length === 0", class="mt-3 text-[13px] text-zinc-500") 저장한 레시피가 없습니다.
                    div(class="mt-3 space-y-2")
                        button(*ngFor="let item of activity.favorites.items", type="button", class="w-full rounded-md border border-zinc-200 p-3 text-left hover:border-emerald-400", (click)="openVersion(item)")
                            p(class="line-clamp-1 text-[13px] font-semibold text-zinc-950") {{ item.version ? item.version.title : '공개 중이 아닌 레시피' }}
                            p(class="mt-1 text-xs text-zinc-500") {{ item.createdAt }}
                div(class="rounded-md border border-zinc-200 bg-white p-4")
                    h2(class="text-[15px] font-semibold text-zinc-950") 최근 본 레시피
                    div(*ngIf="activity.recentViews.items.length === 0", class="mt-3 text-[13px] text-zinc-500") 최근 본 레시피가 없습니다.
                    div(class="mt-3 space-y-2")
                        button(*ngFor="let item of activity.recentViews.items", type="button", class="w-full rounded-md border border-zinc-200 p-3 text-left hover:border-emerald-400", (click)="openVersion(item)")
                            p(class="line-clamp-1 text-[13px] font-semibold text-zinc-950") {{ item.version ? item.version.title : '공개 중이 아닌 레시피' }}
                            p(class="mt-1 text-xs text-zinc-500") {{ item.viewedAt }} · {{ item.viewCount }}회
                div(class="rounded-md border border-zinc-200 bg-white p-4")
                    h2(class="text-[15px] font-semibold text-zinc-950") 댓글 내역
                    div(*ngIf="activity.comments.items.length === 0", class="mt-3 text-[13px] text-zinc-500") 댓글 내역이 없습니다.
                    div(class="mt-3 space-y-2")
                        article(*ngFor="let item of activity.comments.items", class="rounded-md border border-zinc-200 p-3")
                            p(class="line-clamp-2 text-[13px] text-zinc-700") {{ item.content }}
                            p(class="mt-1 text-xs text-zinc-500") {{ statusLabel(item.status) }} · {{ item.createdAt }}
                div(class="rounded-md border border-zinc-200 bg-white p-4")
                    h2(class="text-[15px] font-semibold text-zinc-950") 수정 요청 내역
                    div(*ngIf="activity.editRequests.items.length === 0", class="mt-3 text-[13px] text-zinc-500") 수정 요청 내역이 없습니다.
                    div(class="mt-3 space-y-2")
                        article(*ngFor="let item of activity.editRequests.items", class="rounded-md border border-zinc-200 p-3")
                            div(class="flex items-center justify-between gap-2")
                                p(class="text-[13px] font-semibold text-zinc-950") {{ item.requestType }}
                                span(class="rounded-md bg-zinc-100 px-2 py-1 text-xs text-zinc-600") {{ statusLabel(item.status) }}
                            p(class="mt-2 line-clamp-2 text-[13px] text-zinc-600") {{ item.content }}
                div(class="rounded-md border border-zinc-200 bg-white p-4 lg:col-span-2")
                    h2(class="text-[15px] font-semibold text-zinc-950") AI 개량 요청 내역
                    div(*ngIf="activity.aiModifications.items.length === 0", class="mt-3 text-[13px] text-zinc-500") AI 개량 요청 내역이 없습니다.
                    div(class="mt-3 grid gap-2 lg:grid-cols-2")
                        article(*ngFor="let item of activity.aiModifications.items", class="rounded-md border border-zinc-200 p-3")
                            div(class="flex items-center justify-between gap-2")
                                p(class="text-[13px] font-semibold text-zinc-950") {{ item.purpose }}
                                span(class="rounded-md bg-amber-50 px-2 py-1 text-xs text-amber-700") {{ statusLabel(item.status) }}
                            p(class="mt-2 text-xs text-zinc-500") {{ item.createdAt }}

            section(*ngIf="activeTab === 'preference'", class="rounded-md border border-zinc-200 bg-white p-4 sm:p-5")
                h2(class="text-lg font-semibold text-zinc-950") 개인화 설정
                div(class="mt-5 grid gap-5 lg:grid-cols-2")
                    div
                        h3(class="text-[15px] font-semibold text-zinc-950") 관심 식단
                        div(class="mt-3 flex flex-wrap gap-2")
                            button(*ngFor="let item of options.dietTypes", type="button", class="rounded-md border px-3 py-2 text-[13px]", [class.border-emerald-500]="selected('preferredDietTypes', item)", [class.bg-emerald-50]="selected('preferredDietTypes', item)", [class.text-emerald-800]="selected('preferredDietTypes', item)", [class.border-zinc-200]="!selected('preferredDietTypes', item)", [class.text-zinc-600]="!selected('preferredDietTypes', item)", (click)="toggleArray('preferredDietTypes', item)") {{ item }}
                    div
                        h3(class="text-[15px] font-semibold text-zinc-950") 조리도구
                        div(class="mt-3 flex flex-wrap gap-2")
                            button(*ngFor="let item of options.tools", type="button", class="rounded-md border px-3 py-2 text-[13px]", [class.border-emerald-500]="selected('cookingTools', item)", [class.bg-emerald-50]="selected('cookingTools', item)", [class.text-emerald-800]="selected('cookingTools', item)", [class.border-zinc-200]="!selected('cookingTools', item)", [class.text-zinc-600]="!selected('cookingTools', item)", (click)="toggleArray('cookingTools', item)") {{ item }}
                    label(class="block")
                        span(class="text-xs font-semibold text-zinc-600") 알레르기
                        input(type="text", [(ngModel)]="preferenceText.allergies", name="mypageAllergies", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600", placeholder="달걀, 우유")
                    label(class="block")
                        span(class="text-xs font-semibold text-zinc-600") 비선호 재료
                        input(type="text", [(ngModel)]="preferenceText.dislikedIngredients", name="mypageDisliked", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600", placeholder="고수, 오이")
                    label(class="block")
                        span(class="text-xs font-semibold text-zinc-600") 선호 조리 시간
                        input(type="number", min="0", [(ngModel)]="preference.preferredCookingTime", name="mypageCookingTime", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600", placeholder="분 단위")
                    label(class="block")
                        span(class="text-xs font-semibold text-zinc-600") 아기 월령
                        input(type="number", min="0", [(ngModel)]="preference.babyAgeMonth", name="mypageBabyAge", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600", placeholder="개월")
                    label(class="block")
                        span(class="text-xs font-semibold text-zinc-600") 나트륨 선호
                        select([(ngModel)]="preference.sodiumPreference", name="mypageSodium", class="mt-1 block w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            option(*ngFor="let item of options.sodiumPreferences", [value]="item.value") {{ item.label }}
                    label(class="block")
                        span(class="text-xs font-semibold text-zinc-600") 식감 선호
                        select([(ngModel)]="preference.texturePreference", name="mypageTexture", class="mt-1 block w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                            option(*ngFor="let item of options.texturePreferences", [value]="item.value") {{ item.label }}
                div(class="mt-5 flex justify-end")
                    button(type="button", class="rounded-md bg-emerald-600 px-4 py-2 text-[13px] font-semibold text-white hover:bg-emerald-700 disabled:cursor-not-allowed disabled:bg-zinc-300", [disabled]="savingPreference", (click)="savePreference()") 설정 저장

            section(*ngIf="activeTab === 'profile' && profile", class="rounded-md border border-zinc-200 bg-white p-4 sm:p-5")
                h2(class="text-lg font-semibold text-zinc-950") 프로필 정보
                div(class="mt-5 grid gap-4 sm:grid-cols-2")
                    label(class="block")
                        span(class="text-xs font-semibold text-zinc-600") 이메일
                        input(type="email", [value]="profile.email", disabled, class="mt-1 block w-full rounded-md border border-zinc-200 bg-zinc-50 px-3 py-2 text-[13px] text-zinc-500")
                    label(class="block")
                        span(class="text-xs font-semibold text-zinc-600") 역할
                        input(type="text", [value]="profile.role", disabled, class="mt-1 block w-full rounded-md border border-zinc-200 bg-zinc-50 px-3 py-2 text-[13px] text-zinc-500")
                    label(class="block")
                        span(class="text-xs font-semibold text-zinc-600") 구독 플랜
                        input(type="text", [value]="subscriptionLabel()", disabled, class="mt-1 block w-full rounded-md border border-zinc-200 bg-zinc-50 px-3 py-2 text-[13px] text-zinc-500")
                    label(class="block")
                        span(class="text-xs font-semibold text-zinc-600") 구독 만료일
                        input(type="text", [value]="subscriptionExpiresAt()", disabled, class="mt-1 block w-full rounded-md border border-zinc-200 bg-zinc-50 px-3 py-2 text-[13px] text-zinc-500")
                    label(class="block sm:col-span-2")
                        span(class="text-xs font-semibold text-zinc-600") 닉네임
                        input(type="text", [(ngModel)]="profile.nickname", name="mypageNickname", class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-[13px] outline-none focus:border-emerald-600 focus:ring-1 focus:ring-emerald-600")
                div(class="mt-5 flex justify-end")
                    button(type="button", class="rounded-md bg-emerald-600 px-4 py-2 text-[13px] font-semibold text-white hover:bg-emerald-700 disabled:cursor-not-allowed disabled:bg-zinc-300", [disabled]="savingProfile", (click)="saveProfile()") 프로필 저장
