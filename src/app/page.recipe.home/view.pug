section(class="relative overflow-hidden bg-zinc-950")
    div(class="absolute inset-0 bg-cover bg-center", style="background-image: linear-gradient(90deg, rgba(9,9,11,.88), rgba(9,9,11,.48), rgba(9,9,11,.12)), url('https://images.unsplash.com/photo-1498837167922-ddd27525d352?auto=format&fit=crop&w=1800&q=80')")
    div(class="relative mx-auto grid min-h-[430px] max-w-7xl items-center px-4 py-14 sm:px-6 lg:px-8")
        div(class="max-w-2xl")
            h1(class="text-4xl font-semibold tracking-normal text-white sm:text-5xl") Recipe Taste
            p(class="mt-4 max-w-xl text-[15px] leading-7 text-zinc-100") 한국어 레시피를 찾고, 저염식과 이유식 관점으로 다시 살펴봅니다.
            form(class="mt-8 flex w-full max-w-xl flex-col gap-2 sm:flex-row", (submit)="$event.preventDefault(); search()")
                input(type="search", [(ngModel)]="query", name="homeSearch", class="min-h-[44px] flex-1 rounded-md border border-white/20 bg-white px-3 py-2 text-[13px] text-zinc-950 outline-none placeholder:text-zinc-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500", placeholder="레시피, 재료, 태그 검색")
                button(type="submit", class="inline-flex min-h-[44px] items-center justify-center gap-2 rounded-md bg-emerald-600 px-4 text-[13px] font-semibold text-white hover:bg-emerald-700")
                    svg(class="size-4", fill="none", viewBox="0 0 24 24", stroke="currentColor", stroke-width="2")
                        path(stroke-linecap="round", stroke-linejoin="round", d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z")
                    span 검색
            div(class="mt-4 flex flex-wrap gap-2")
                button(*ngFor="let keyword of keywords", type="button", class="rounded-md border border-white/20 bg-white/10 px-3 py-1.5 text-xs font-medium text-white hover:bg-white/20", (click)="search(keyword)") {{ keyword }}
            div(class="mt-8 flex flex-wrap gap-2")
                button(type="button", class="rounded-md bg-white px-4 py-2 text-[13px] font-semibold text-zinc-950 hover:bg-zinc-100", (click)="go('/recipes/low-sodium')") 저염식 보기
                button(type="button", class="rounded-md border border-white/30 px-4 py-2 text-[13px] font-semibold text-white hover:bg-white/10", (click)="go('/recipes/baby-food')") 이유식 보기
                button(type="button", class="rounded-md border border-white/30 px-4 py-2 text-[13px] font-semibold text-white hover:bg-white/10", (click)="go('/ai/modify')") AI 개량 요청

section(*ngIf="!loading && recommended.length > 0", class="bg-white py-10")
    div(class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8")
        div(class="flex items-end justify-between gap-4")
            div
                h2(class="text-lg font-semibold text-zinc-950") 맞춤 추천
                p(class="mt-1 text-[13px] text-zinc-500") 즐겨찾기와 최근 조회, 선호 식단을 반영한 추천
            button(type="button", class="hidden rounded-md border border-zinc-200 px-3 py-2 text-[13px] font-medium text-zinc-700 hover:bg-zinc-100 sm:inline-flex", (click)="go('/recipes')") 전체 보기

        div(class="mt-5 grid gap-4 md:grid-cols-3")
            article(*ngFor="let item of recommended; let index = index", class="overflow-hidden rounded-md border border-zinc-200 bg-white transition-shadow hover:shadow-md")
                button(type="button", class="block w-full text-left", (click)="openDish(item)")
                    div(class="h-40 bg-cover bg-center", [style.backgroundImage]="imageStyle(item, index)")
                    div(class="space-y-2 p-4")
                        div(class="flex items-center justify-between gap-2")
                            span(class="truncate text-xs font-medium text-emerald-700") {{ item.category || '레시피' }}
                            span(class="shrink-0 text-xs text-zinc-500") 조회 {{ item.viewCount || 0 }}
                        h3(class="line-clamp-2 text-[15px] font-semibold text-zinc-950") {{ item.name }}
                        p(class="line-clamp-2 min-h-[40px] text-[13px] leading-5 text-zinc-600") {{ item.description || '레시피 설명이 준비 중입니다.' }}
                        div(class="flex flex-wrap gap-1.5")
                            span(*ngFor="let tag of item.tags?.slice(0, 3)", class="rounded bg-zinc-100 px-2 py-1 text-xs text-zinc-600") {{ tag }}

section(class="bg-white py-10")
    div(class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8")
        div(class="flex items-end justify-between gap-4")
            div
                h2(class="text-lg font-semibold text-zinc-950") 인기 레시피
                p(class="mt-1 text-[13px] text-zinc-500") 조회수가 높은 승인 레시피
            button(type="button", class="hidden rounded-md border border-zinc-200 px-3 py-2 text-[13px] font-medium text-zinc-700 hover:bg-zinc-100 sm:inline-flex", (click)="go('/recipes?sort=view_count')") 전체 보기

        div(*ngIf="loading", class="mt-5 grid gap-4 md:grid-cols-3")
            div(*ngFor="let item of [1,2,3]", class="h-[260px] animate-pulse rounded-md bg-zinc-100")

        div(*ngIf="!loading && popular.length === 0", class="mt-5 rounded-md border border-dashed border-zinc-300 px-4 py-8 text-center text-[13px] text-zinc-500") 승인된 레시피가 없습니다.

        div(*ngIf="!loading && popular.length > 0", class="mt-5 grid gap-4 md:grid-cols-3")
            article(*ngFor="let item of popular; let index = index", class="overflow-hidden rounded-md border border-zinc-200 bg-white transition-shadow hover:shadow-md")
                button(type="button", class="block w-full text-left", (click)="openDish(item)")
                    div(class="h-40 bg-cover bg-center", [style.backgroundImage]="imageStyle(item, index)")
                    div(class="space-y-2 p-4")
                        div(class="flex items-center justify-between gap-2")
                            span(class="truncate text-xs font-medium text-emerald-700") {{ item.category || '레시피' }}
                            span(class="shrink-0 text-xs text-zinc-500") 조회 {{ item.viewCount || 0 }}
                        h3(class="line-clamp-2 text-[15px] font-semibold text-zinc-950") {{ item.name }}
                        p(class="line-clamp-2 min-h-[40px] text-[13px] leading-5 text-zinc-600") {{ item.description || '레시피 설명이 준비 중입니다.' }}
                        div(class="flex flex-wrap gap-1.5")
                            span(*ngFor="let tag of item.tags?.slice(0, 3)", class="rounded bg-zinc-100 px-2 py-1 text-xs text-zinc-600") {{ tag }}

section(class="bg-zinc-50 py-10")
    div(class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[1fr_360px] lg:px-8")
        div
            div(class="flex items-end justify-between gap-4")
                div
                    h2(class="text-lg font-semibold text-zinc-950") 최신 업데이트
                    p(class="mt-1 text-[13px] text-zinc-500") 공개 승인된 최신 레시피
                button(type="button", class="rounded-md border border-zinc-200 px-3 py-2 text-[13px] font-medium text-zinc-700 hover:bg-zinc-100", (click)="go('/recipes?sort=latest')") 더 보기
            div(class="mt-5 grid gap-3 sm:grid-cols-2")
                button(*ngFor="let item of latest; let index = index", type="button", class="flex min-h-[104px] gap-3 rounded-md border border-zinc-200 bg-white p-3 text-left hover:border-emerald-300", (click)="openDish(item)")
                    div(class="h-20 w-24 shrink-0 rounded bg-cover bg-center", [style.backgroundImage]="imageStyle(item, index + 1)")
                    div(class="min-w-0 flex-1")
                        div(class="flex items-center gap-2")
                            span(class="truncate text-xs font-medium text-emerald-700") {{ item.category || '레시피' }}
                            span(class="text-xs text-zinc-400") {{ item.createdAt }}
                        h3(class="mt-1 line-clamp-2 text-[13px] font-semibold text-zinc-950") {{ item.name }}
                        p(class="mt-1 line-clamp-2 text-xs leading-5 text-zinc-500") {{ item.description || '설명이 준비 중입니다.' }}

        aside(class="space-y-4")
            div
                h2(class="text-lg font-semibold text-zinc-950") 랜덤 레시피
                p(class="mt-1 text-[13px] text-zinc-500") 오늘 다시 볼 만한 두 가지
            button(*ngFor="let item of randomItems; let index = index", type="button", class="block w-full overflow-hidden rounded-md border border-zinc-200 bg-white text-left hover:border-emerald-300", (click)="openDish(item)")
                div(class="h-36 bg-cover bg-center", [style.backgroundImage]="imageStyle(item, index + 2)")
                div(class="p-4")
                    h3(class="line-clamp-1 text-[15px] font-semibold text-zinc-950") {{ item.name }}
                    p(class="mt-1 line-clamp-2 text-[13px] leading-5 text-zinc-600") {{ item.description || '레시피 설명이 준비 중입니다.' }}

section(class="bg-white py-10")
    div(class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8")
        div(class="flex items-end justify-between gap-4")
            div
                h2(class="text-lg font-semibold text-zinc-950") 특수식단 개선
                p(class="mt-1 text-[13px] text-zinc-500") 원본과 개량 포인트를 나란히 확인
            button(type="button", class="rounded-md bg-zinc-950 px-3 py-2 text-[13px] font-semibold text-white hover:bg-zinc-800", (click)="go('/ai/modify')") AI 개량 요청

        div(class="mt-5 grid gap-4 md:grid-cols-2")
            article(*ngFor="let panel of dietPanels", class="rounded-md border border-zinc-200 bg-white p-4")
                div(class="flex items-center justify-between gap-3")
                    h3(class="text-[15px] font-semibold text-zinc-950") {{ panel.title }}
                    button(type="button", class="rounded-md border border-zinc-200 px-3 py-1.5 text-xs font-medium text-zinc-700 hover:bg-zinc-100", (click)="go(panel.href)") 보기
                div(class="mt-4 grid gap-3 sm:grid-cols-2")
                    div(class="rounded-md bg-zinc-50 p-3")
                        div(class="text-xs font-medium text-zinc-500") 원본
                        p(class="mt-2 text-[13px] leading-5 text-zinc-700") {{ panel.before }}
                    div(class="rounded-md bg-emerald-50 p-3")
                        div(class="text-xs font-medium text-emerald-700") 개량
                        p(class="mt-2 text-[13px] leading-5 text-emerald-900") {{ panel.after }}
